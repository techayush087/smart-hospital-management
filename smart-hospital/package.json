{
  "name": "smart-hospital",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "mock-api": "node mock-server.js",
    "dev": "concurrently -n ng,api -c blue,green \"npm:start\" \"npm:mock-api\"",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "e2e": "concurrently -k -s first -n ng,api,cy -c blue,green,magenta \"npm:start\" \"npm:mock-api\" \"npx wait-on http://localhost:4200 http://localhost:3000/api/doctors && cypress run\"",
    "start:api": "node mock-server.js"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.16",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/effects": "^21.1.1",
    "@ngrx/entity": "^21.1.1",
    "@ngrx/store": "^21.1.1",
    "@ngrx/store-devtools": "^21.1.1",
    "lottie-web": "^5.13.0",
    "ngx-lottie": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.0",
    "@ngrx/schematics": "^21.1.1",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.2.1",
    "cypress": "^13.17.0",
    "jsdom": "^28.0.0",
    "json-server": "^0.17.4",
    "jsonwebtoken": "^8.5.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^8.0.5"
  }
}
